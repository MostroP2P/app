#!/usr/bin/env bash
# Pre-commit hook: lint and test checks
# Install: git config core.hooksPath .githooks
set -e

echo "▶ cargo test..."
(cd rust && cargo test 2>&1)

echo "▶ cargo clippy..."
(cd rust && cargo clippy -- -D warnings 2>&1)

echo "▶ cargo check (wasm32)..."
(cd rust && cargo check --target wasm32-unknown-unknown 2>&1)

echo "▶ flutter analyze..."
flutter analyze 2>&1

echo "✓ All checks passed"
